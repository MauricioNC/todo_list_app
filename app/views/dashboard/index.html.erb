<%= turbo_frame_tag new_task_path do %>
  <%= link_to "New task", new_task_path, class: "p-2 bg-blue-500 text-white rounded" %>
<% end %>

<% if @tasks.any? %>
  <%= turbo_frame_tag "tasks" do %>
    <ul>
      <% @tasks.each do |task| %>
        <li id="<%= dom_id(task) %>"><%= link_to task.title, task_path(task), data: { turbo_frame: "_top" } %></li>
      <% end %>
    </ul>
  <% end %>
<% else %>
  <p>No tasks found.</p>
<% end %>